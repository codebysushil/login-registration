{
    "name": "sushilk/auth-kit",
    "description": "Auth kit",
    "type": "project",
    "require": {
        "phpmailer/phpmailer": "^7.1",
        "vlucas/phpdotenv": "^5.6",
        "egulias/email-validator": "^4.0",
        "monolog/monolog": "^3.10",
        "symfony/cache": "^8.1"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Sushil Kumar",
            "email": "sushilkumbhar77@gmail.com"
        }
    ],
    "config": {
        "process-timeout": 0
    },
    "scripts": {
        "serve": [
            "@php -S localhost:8800 -t public"
        ]
    },
    "minimum-stability": "dev",
    "require-dev": {
        "symfony/var-dumper": "^8.1"
    },
    "prefer-stable": true
}
